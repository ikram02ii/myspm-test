# Copy to .env and fill in values.

# Database
DATABASE_URL=
RAG_DATABASE_URL=

PORT=3000
NODE_ENV=development
JWT_SECRET=

# Speech-to-text (oral practice) — /api/stt/*
# Qwen falls back to QWEN_GRADING_API_KEY or ALIBABA_LLM_API_KEY if QWEN_API_KEY is unset
QWEN_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-transcribe
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=southeastasia

# Optional: disable JWT on STT routes (defaults to same as DISABLE_RAG_AUTH)
# DISABLE_STT_AUTH=true
